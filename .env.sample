# App URLs
NEXT_PUBLIC_URL=http://2.24.203.147:3000
NEXTAUTH_URL=http://2.24.203.147:3000

# Backend URLs
NEXT_PUBLIC_API_URL=http://2.24.203.147:5000/api
API_URL=http://2.24.203.147:5000/api
NEXT_PUBLIC_API_BASE_URL=http://2.24.203.147:5000/api

# Auth
AUTH_SECRET=change-this-secret
AUTH_DEBUG=true

# Vercel KV auth storage
AUTH_KV_REST_API_URL=
AUTH_KV_REST_API_TOKEN=

# Mock and local runtime flags
NEXT_PUBLIC_API_MOCKING=disabled
NEXT_PUBLIC_DISABLE_MSW=false
APP_ENV=local

# Script helpers
API_BASE_URL=http://2.24.203.147:5000
RETREAT_ID=
NUM_PARTICIPANTS=5

# Platform-managed variables like NODE_ENV and VERCEL are usually provided
# by the runtime and should not normally be hardcoded here.

# Frontend
NEXT_PUBLIC_URL=http://2.24.203.147:3000

# Backend URLs
# URL pública usada pelo browser.
NEXT_PUBLIC_API_URL=http://2.24.203.147:5000/api
NEXT_PUBLIC_API_BASE_URL=http://2.24.203.147:5000/api

# URL usada pelo server-side (Auth.js/SSR). Em Docker, prefira API_URL_INTERNAL.
API_URL=http://2.24.203.147:5000/api

# URL usada somente pelo container frontend para alcançar a API no host.
API_URL_INTERNAL=http://host.docker.internal:5000/api